# =============================================================================
# Job Assist — Environment Variables
# Copy to .env.local (web) or .env (api) and fill in values.
# =============================================================================

# --- Database (Supabase) ---
# Get from Supabase dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM APIs ---
# Gemini: https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=

# Anthropic: https://console.anthropic.com (Phase 2 tailoring)
ANTHROPIC_API_KEY=

# --- Company enrichment (PR #27) ---
# Publishable logo.dev token (NOT the secret/server-side one). Get at
# https://logo.dev/signup — free tier covers ~1000 requests/month, which
# is plenty for ~30 target_companies × 1 lookup each.
LOGO_DEV_TOKEN=
# Gemini model used to generate one-sentence company descriptions.
COMPANY_DESC_MODEL=gemini-2.5-flash-lite
# Failed attempts before the daily sweep stops retrying a row.
# Reset via POST /enrichment/companies/{id}/retry.
COMPANY_ENRICH_MAX_ATTEMPTS=3

# --- Gmail (Week 1-2 backfill + continuous monitoring) ---
# Set up at https://console.cloud.google.com → APIs → Gmail API
# Download credentials.json to apps/api/credentials.json
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# --- Email (Resend, Week 3-4 digest) ---
# https://resend.com/api-keys (free tier: 3000/mo, 100/day)
RESEND_API_KEY=
DIGEST_FROM_EMAIL=digest@yourdomain.com
DIGEST_TO_EMAIL=

# --- Job Aggregator (Week 5-6, optional) ---
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# --- Observability (optional but recommended) ---
SENTRY_DSN=

# --- Web app config ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API config ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
