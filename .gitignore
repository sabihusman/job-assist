# OAuth tokens (Gmail)
apps/api/credentials.json
apps/api/token.json
apps/api/.gmail-cache/

# Private seed data — never committed (see docs/RUNBOOK.md "Data discipline")
# The *.example.json files are the public templates documenting the schema.
apps/api/seeds/*.json
!apps/api/seeds/*.example.json
*.gmail-token
credentials.json

# Operator-personal contact data (PR #39) — Tippie alumni directory and
# any derived JSON. Real PII for ~388 people; must never land in git.
Connecting_With_Classmates_Directory.xlsx
*alumni*.xlsx
apps/api/seeds/contacts.json
/tmp/contacts.json

# OAuth client secrets - never commit
apps/api/credentials/

# Local scratch / credential notes - never commit.
# "Job Assist.txt" holds a plaintext Supabase password + OAuth client id;
# get_token.py is a redundant local OAuth bootstrap (superseded by
# apps/api/scripts/refresh_gmail_oauth.py, which is safe to commit).
Job Assist.txt
/get_token.py

# Claude Code agent session artifacts.
.claude/

# Belt-and-suspenders privacy guard (PUBLIC repo): block stray copies of eval
# verify sheets / corrected sheets — they hold real JD text + email
# subjects/snippets — and Excel lock files, anywhere in the tree, on top of the
# eval/ gitignores. So even `git add -A` can never stage real application data.
verify_sheet*.xlsx
*CORRECTED*.xlsx
~$*
# Any Excel workbook at the REPO ROOT (leading slash = root-only) — strays land
# here when copied out of eval/datasets/. Intentional in-tree .xlsx live under
# their own dirs, not root.
/*.xlsx
